# EuroSec AI — Environment Configuration
# Copy to .env and fill in values. Never commit .env to git.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=EuroSec AI
DEBUG=false
LOG_LEVEL=INFO

# ── Security (REQUIRED) ───────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Local LLM ─────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M

# ── Cloud provider ────────────────────────────────────────────────────────────
# Options: groq | openai | none (local-only mode)
CLOUD_PROVIDER=groq

# Get free key at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# Only needed if CLOUD_PROVIDER=openai
OPENAI_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=data/chroma
AUDIT_DB_PATH=data/audit.db
LOCAL_STORAGE_PATH=data/documents

# ── PII Detection ─────────────────────────────────────────────────────────────
PRESIDIO_THRESHOLD=0.6
PII_BLOCK_ON_UNCERTAINTY=true

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=eurosec-ai
